# --- Claude API (proposal generation) ---
ANTHROPIC_API_KEY=

# --- Telegram approval bot ---
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (the bot only talks to you)
TELEGRAM_CHAT_ID=

# --- Notion projection ---
NOTION_TOKEN=
# Parent page ID under which the "応募管理" database is created (notion:setup)
NOTION_PARENT_PAGE_ID=
# Filled automatically by scripts/setup-notion.ts
NOTION_DATABASE_ID=

# --- Gmail (collection) ---
# OAuth2 client from Google Cloud Console (Desktop app type)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Filled automatically by scripts/gmail-auth.ts
GMAIL_REFRESH_TOKEN=
# Gmail search query for Lancers notification mails
# 注意: 送信元ドメインは lancers.co.jp(lancers.jp ではない)。実メールで確認済み
GMAIL_QUERY=from:noreply@lancers.co.jp newer_than:7d
# Daily mail collection time (HH:MM). Lancers sends one digest mail per day around 10:00-10:25
POLL_DAILY_AT=10:30

# --- Lancers web collection (search page polling) ---
# Poll interval in minutes (0 = disabled). Actual firing has +-5min jitter.
WEB_POLL_INTERVAL_MIN=60
# Only poll within these local hours (24h)
WEB_POLL_HOURS_START=9
WEB_POLL_HOURS_END=22
# Keyword search rotation list (comma-separated)
WEB_SEARCH_KEYWORDS=AI,生成AI,ChatGPT,LLM,チャットボット,自動化,業務効率化,RAG,スクレイピング,GAS,n8n,Next.js
# Category search rotation list (paths under /work/search/, comma-separated)
# 確認済みslug例: system/ai (生成AI・機械学習・ChatGPT), system/ai_automation (AI自動化・エージェント開発),
#   system/chatbot, system/chatgpt, system/tool (業務効率化・RPA), system/websystem, web (Web制作)
WEB_SEARCH_CATEGORIES=system/ai,system/ai_automation,system/chatbot,system/chatgpt,system/tool,system/websystem,web
# Budget lower bound (yen) added to searches. 0 = off.
# Also reduces agent-job (tech-agent) pollution on listing pages
WEB_SEARCH_BUDGET_FROM=10000
# Max search URLs fetched per tick (request budget; adding targets does not increase frequency)
WEB_TARGETS_PER_TICK=4

# --- Logged-in crawl (capture 限定公開 / fully-private jobs) ---
# Requires a logged-in profile (npm run lancers:login). Shares the submitter profile.
# Off by default; enable after lancers:login. Login footprint is account-attributable,
# so this runs at LOW frequency with a daily cap.
WEB_LOGGED_IN_ENABLED=false
# Logged-in crawl interval in minutes (kept higher than anonymous; +-5min jitter)
WEB_LOGGED_IN_INTERVAL_MIN=240
# Hard daily cap on logged-in listing fetches (safety valve)
WEB_LOGGED_IN_MAX_PER_DAY=20
# Run logged-in crawl headless (true for unattended; false shows the real browser)
WEB_LOGGED_IN_HEADLESS=true

# --- Pipeline guards ---
# Maximum applications submitted per day (rate limit)
MAX_APPLICATIONS_PER_DAY=3
# Two-tier score thresholds (0-100):
#   >= FULL_AUTO_SCORE   : auto-generate proposal + send approval card (core specialty)
#   >= LIGHT_NOTIFY_SCORE: send light card only; proposal is generated when you tap
#                          the "interest" button (saves tokens on peripheral jobs)
#   below                : silent skip (still recorded in Notion)
FULL_AUTO_SCORE=70
LIGHT_NOTIFY_SCORE=40
# submit mode: "manual" (default; approval marks ready, you submit by hand)
#              "auto"   (Playwright auto-fills the form; you confirm once more
#                        via Telegram screenshot before the irreversible submit)
SUBMIT_MODE=manual

# --- Playwright auto-submit (SUBMIT_MODE=auto) ---
# Persistent Chrome profile dir (keeps Lancers login + 2FA across runs)
PLAYWRIGHT_PROFILE_DIR=./.playwright-profile
# Run the browser headless during submit. Keep false until calibrated.
PLAYWRIGHT_HEADLESS=false
# Optional: use a real installed browser instead of bundled Chromium.
# Brave (Windows): C:\Users\<you>\AppData\Local\BraveSoftware\Brave-Browser\Application\brave.exe
PLAYWRIGHT_EXECUTABLE_PATH=
# Or an installed channel name: chrome / msedge (leave empty if using EXECUTABLE_PATH)
PLAYWRIGHT_CHANNEL=
# Where submission screenshots are saved (also referenced from Notion)
SCREENSHOT_DIR=./data/screenshots
# Only auto-submit within these local hours (24h). Outside = wait, notify.
SUBMIT_HOURS_START=9
SUBMIT_HOURS_END=22
# Random delay range (seconds) before each submit to avoid burst patterns
SUBMIT_DELAY_MIN_SEC=20
SUBMIT_DELAY_MAX_SEC=90

# --- Storage ---
DATABASE_PATH=./data/onboard.sqlite
PROFILE_PATH=./profile.yaml
# knowledge-base(SSoT)のパス。profile.yaml は `npm run profile:sync` でここから自動生成される
KB_PATH=../knowledge-base
