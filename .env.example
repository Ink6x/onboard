# --- Claude API (proposal generation) ---
ANTHROPIC_API_KEY=

# --- Telegram approval bot ---
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (the bot only talks to you)
TELEGRAM_CHAT_ID=

# --- Notion projection ---
NOTION_TOKEN=
# Parent page ID under which the "応募管理" database is created (notion:setup)
NOTION_PARENT_PAGE_ID=
# Filled automatically by scripts/setup-notion.ts
NOTION_DATABASE_ID=

# --- Gmail (collection) ---
# OAuth2 client from Google Cloud Console (Desktop app type)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Filled automatically by scripts/gmail-auth.ts
GMAIL_REFRESH_TOKEN=
# Gmail search query for Lancers notification mails
# 注意: 送信元ドメインは lancers.co.jp(lancers.jp ではない)。実メールで確認済み
GMAIL_QUERY=from:noreply@lancers.co.jp newer_than:7d
# Polling interval in minutes
POLL_INTERVAL_MINUTES=15

# --- Pipeline guards ---
# Maximum applications submitted per day (rate limit)
MAX_APPLICATIONS_PER_DAY=3
# Minimum fit score (0-100) required to request approval; below = auto-skip
MIN_FIT_SCORE=60
# submit mode: "manual" (default; approval marks ready, you submit by hand)
#              "auto"   (Playwright auto-fills the form; you confirm once more
#                        via Telegram screenshot before the irreversible submit)
SUBMIT_MODE=manual

# --- Playwright auto-submit (SUBMIT_MODE=auto) ---
# Persistent Chrome profile dir (keeps Lancers login + 2FA across runs)
PLAYWRIGHT_PROFILE_DIR=./.playwright-profile
# Run the browser headless during submit. Keep false until calibrated.
PLAYWRIGHT_HEADLESS=false
# Optional: use a real installed browser instead of bundled Chromium.
# Brave (Windows): C:\Users\<you>\AppData\Local\BraveSoftware\Brave-Browser\Application\brave.exe
PLAYWRIGHT_EXECUTABLE_PATH=
# Or an installed channel name: chrome / msedge (leave empty if using EXECUTABLE_PATH)
PLAYWRIGHT_CHANNEL=
# Where submission screenshots are saved (also referenced from Notion)
SCREENSHOT_DIR=./data/screenshots
# Only auto-submit within these local hours (24h). Outside = wait, notify.
SUBMIT_HOURS_START=9
SUBMIT_HOURS_END=22
# Random delay range (seconds) before each submit to avoid burst patterns
SUBMIT_DELAY_MIN_SEC=20
SUBMIT_DELAY_MAX_SEC=90

# --- Storage ---
DATABASE_PATH=./data/onboard.sqlite
PROFILE_PATH=./profile.yaml
