{
  "name": "onboard",
  "version": "0.1.0",
  "private": true,
  "description": "Lancers semi-autonomous application system: Gmail collection -> AI proposal -> Telegram approval -> Notion projection",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gmail:auth": "tsx scripts/gmail-auth.ts",
    "notion:setup": "tsx scripts/setup-notion.ts",
    "notion:migrate": "tsx scripts/notion-migrate.ts",
    "lancers:login": "tsx scripts/lancers-login.ts",
    "lancers:calibrate": "tsx scripts/lancers-calibrate.ts",
    "lancers:testfill": "tsx scripts/test-fill.ts",
    "requeue": "tsx scripts/requeue.ts",
    "web:collect": "tsx scripts/web-collect-once.ts",
    "lancers:survey": "tsx scripts/lancers-login-survey.ts",
    "e2e:dummy": "tsx scripts/inject-dummy.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@notionhq/client": "^2.3.0",
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "grammy": "^1.34.0",
    "playwright": "^1.60.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
